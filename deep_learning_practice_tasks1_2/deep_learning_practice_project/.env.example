# Copy this file to .env. Never commit the real .env file.
LLM_API_KEY=replace-with-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=replace-with-provider-model-name
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=1600
LLM_JSON_MODE=true
# hybrid: local rules handle simple commands; always: model plans every non-help task.
LLM_PLANNER_MODE=hybrid
