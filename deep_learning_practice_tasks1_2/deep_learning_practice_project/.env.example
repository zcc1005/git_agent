# Copy this file to .env. Never commit the real .env file.
# deepseek 或 c4ai；也可运行 scripts\switch_llm_provider.cmd，切换后重启 Web 服务。
LLM_PROVIDER=deepseek
LLM_DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_DEEPSEEK_MODEL=deepseek-v4-pro
LLM_C4AI_API_KEY=replace-with-your-c4ai-api-key
LLM_C4AI_BASE_URL=https://c4ai.ccccltd.cn/api/compatible/v1
LLM_C4AI_MODEL=jiaorong-deepseek-v4-pro
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=1600
LLM_JSON_MODE=true
# hybrid: local rules handle simple commands; always: model plans every non-help task.
LLM_PLANNER_MODE=hybrid

# RTSP source URLs stay in the environment; never put camera credentials in video_sources.json.
MAIN_MONITOR_RTSP_URL=rtsp://127.0.0.1:8554/main-monitor
