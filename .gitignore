# Keep generated runs ignored, but allow YOLO training outputs and weights.
!deep_learning_practice_tasks1_2/deep_learning_practice_project/runs/
deep_learning_practice_tasks1_2/deep_learning_practice_project/runs/*
!deep_learning_practice_tasks1_2/deep_learning_practice_project/runs/yolo/
!deep_learning_practice_tasks1_2/deep_learning_practice_project/runs/yolo/**

# Final safeguard: YOLO run metadata may be versioned, but never add model binaries.
# Keep already-downloaded/previously-tracked weights on disk; this rule applies to
# newly created or newly added model files.
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.engine
