.git
.gitignore
.env
.env.*
!.env.example

# Local Python environments and caches
**/__pycache__/
**/.pytest_cache/
**/.local/

# Large source archives and unrelated binaries at the repository root
*.zip
*.tar
*.tar.gz
*.7z
*.exe

# Generated application state and model-training outputs.  These are runtime
# data and should be mounted or generated inside the container instead.
deep_learning_practice_tasks1_2/deep_learning_practice_project/outputs/
deep_learning_practice_tasks1_2/deep_learning_practice_project/runs/
deep_learning_practice_tasks1_2/deep_learning_practice_project/data/

# Local logs and editor files
**/*.log
**/.idea/
**/.vscode/
